# Copier ce fichier en .env et remplir les valeurs

# Django
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données PostgreSQL
# Option 1 : URL complète (Railway, Render...)
DATABASE_URL=postgresql://user:password@localhost:5432/boutique_db

# Option 2 : paramètres séparés (si pas de DATABASE_URL)
DB_NAME=boutique_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Cloudinary (images)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS (origines autorisées)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email (Gmail SMTP)
# En dev : laisser EMAIL_BACKEND vide → les emails s'affichent dans la console
# En prod : utiliser smtp.EmailBackend + mot de passe d'application Gmail
ADMIN_EMAIL=bam616173@gmail.com
DEFAULT_FROM_EMAIL=Boutique Electronics <bam616173@gmail.com>
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=bam616173@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password
